{
  "name": "@sailingnaturali/signalk-currents",
  "version": "0.9.2",
  "description": "Publish CHS/NOAA tidal-current predictions to SignalK — environment.current + a /currents resource, for a configured station list.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "refresh:constituents": "tsx scripts/refresh-constituents.ts"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "signalk-webapp",
    "tidal-currents",
    "currents",
    "marine"
  ],
  "author": "Bryan Clark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sailingnaturali/signalk-currents.git"
  },
  "homepage": "https://github.com/sailingnaturali/signalk-currents#readme",
  "bugs": {
    "url": "https://github.com/sailingnaturali/signalk-currents/issues"
  },
  "signalk": {
    "displayName": "Currents",
    "screenshots": [
      "./docs/screenshots/data-table.png"
    ]
  },
  "files": [
    "dist",
    "data",
    "public",
    "docs/screenshots/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@neaps/tide-predictor": "^0.10.0",
    "@sailingnaturali/chs-constituents": "^0.1.0",
    "@sailingnaturali/current-stations": "^0.1.0",
    "@sailingnaturali/station-corrections": "^2.0.0",
    "@signalk/server-api": "^2.0.0",
    "geolib": "^3.3.4"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
